{
  "name": "@vac/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm build && electron .",
    "package": "electron-builder --publish never",
    "test": "pnpm build"
  },
  "dependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.0.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.vac.desktop",
    "productName": "VAC",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "hardenedRuntime": true
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
