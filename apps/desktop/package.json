{
  "name": "@vac/desktop",
  "version": "0.1.0",
  "private": true,
  "description": "VAC Electron desktop shell.",
  "author": "VAC",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "pnpm --workspace-root --filter @vac/ai-core build && pnpm --workspace-root --filter @vac/memory build && pnpm build && electron .",
    "package": "electron-builder --publish never",
    "test": "pnpm build"
  },
  "dependencies": {
    "@vac/ai-core": "workspace:*",
    "@vac/memory": "workspace:*",
    "@vac/offline": "workspace:*",
    "better-sqlite3": "^12.4.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.2",
    "electron": "^41.5.0",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.vac.desktop",
    "productName": "VAC",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../renderer/dist",
        "to": "renderer",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "hardenedRuntime": true
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
